# Supabase — sacá estos valores de tu proyecto en https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Schema donde viven las tablas
NEXT_PUBLIC_SUPABASE_SCHEMA=boutique

# WhatsApp de la tienda para el botón "Comprar por WhatsApp" (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=595981772872

# El login del admin ahora usa Supabase Auth.
# 1. Crear el usuario en Supabase → Authentication → Users
# 2. Insertar su user_id en boutique.admins (ver supabase/admins.sql)
